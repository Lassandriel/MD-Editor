{
  "name": "md-editor",
  "version": "1.1.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.lassandriel.mdeditor",
    "productName": "MD Editor",
    "compression": "maximum",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true
    },
    "files": [
      "**/*",
      "!dist/*",
      "!node_modules/*",
      "!IDEAS.md",
      "!README.md",
      "!BUG_report.png",
      "!LICENSE",
      "!package-lock.json",
      "!public/MD Editor.png",
      "!.git/*",
      "!.gitignore"
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown File",
        "role": "Editor"
      },
      {
        "ext": "txt",
        "name": "Text File",
        "role": "Editor"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lassandriel/MD-Editor.git"
  },
  "keywords": [],
  "author": "Lassandriel",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Lassandriel/MD-Editor/issues"
  },
  "homepage": "https://github.com/Lassandriel/MD-Editor#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1"
  }
}
